KOALAPARTY_VERSION=0.8.0
KOALAPARTY_ADDR=:8080
KOALAPARTY_DB=/data/koalaparty.db
KOALAPARTY_WEB_ROOT=/app/web
KOALAPARTY_TRUSTED_ORIGINS=https://party.koalastuff.net
KOALAPARTY_COOKIE_SECURE=true
KOALAPARTY_PRODUCTION=true
KOALAPARTY_TRUSTED_PROXIES=172.16.0.0/12
KOALAPARTY_PUBLIC_ROOMS=false
# When true (default) the server fetches real video titles from YouTube's oEmbed
# endpoint as videos are queued. This is a server-to-YouTube request (the video
# ID and the server's IP, never the viewer's). Set to false for zero outbound
# calls; titles then fall back to "YouTube video <id>".
KOALAPARTY_YOUTUBE_METADATA=true
# When true (default) rooms can auto-skip sponsor/intro/outro segments using
# SponsorBlock. The server fetches segments via SponsorBlock's privacy-preserving
# hash-prefix endpoint (only the first 4 hex chars of the video ID's SHA-256 are
# sent, never the full ID or the viewer's IP). Segment data is CC BY-NC-SA 4.0.
# Set to false for zero SponsorBlock calls. It can also be toggled per room.
KOALAPARTY_SPONSORBLOCK=true
KOALAPARTY_SESSION_TTL=168h
KOALAPARTY_ACTIVITY_MAX_AGE=720h
KOALAPARTY_ACTIVITY_MAX_EVENTS=200
KOALAPARTY_ROOM_MAX_IDLE=8760h
